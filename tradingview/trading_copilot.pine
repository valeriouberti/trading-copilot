// This Pine Script™ source code is subject to the terms of the Mozilla Public License 2.0 at https://mozilla.org/MPL/2.0/
// © Trading Copilot — EMA Pullback Strategy with LLM Bias Filter

//@version=6
indicator("Trading Copilot — EMA Pullback", overlay=true, max_labels_count=500, max_lines_count=500)

// ─────────────────────────────────────────────────────────────────────
// INPUTS
// ─────────────────────────────────────────────────────────────────────

// Manual bias from Python report (set this each morning)
i_bias = input.string("NEUTRAL", "LLM Bias (from report)", options=["BULLISH", "BEARISH", "NEUTRAL"], group="Report Settings")
i_regime = input.string("NEUTRAL", "Regime (from report)", options=["LONG", "SHORT", "NEUTRAL"], group="Report Settings")
i_confidence = input.int(50, "Report Confidence %", minval=0, maxval=100, group="Report Settings")
i_flags = input.bool(false, "Validation Flags Present?", tooltip="Set TRUE if the report shows any red flags (SENTIMENT_MISMATCH, DIRECTION_CONFLICT). Forces NEUTRAL regime.", group="Report Settings")

// EMA settings
i_ema_fast = input.int(20, "EMA Fast Length", minval=5, maxval=50, group="EMA Settings")
i_ema_slow = input.int(50, "EMA Slow Length", minval=20, maxval=200, group="EMA Settings")

// RSI settings
i_rsi_len = input.int(14, "RSI Length", minval=5, maxval=30, group="RSI Settings")
i_rsi_ob = input.int(70, "RSI Overbought", minval=60, maxval=90, group="RSI Settings")
i_rsi_os = input.int(30, "RSI Oversold", minval=10, maxval=40, group="RSI Settings")

// ATR settings (for SL/TP)
i_atr_len = input.int(14, "ATR Length", minval=5, maxval=30, group="Risk Management")
i_sl_mult = input.float(1.5, "SL Multiplier (× ATR)", minval=0.5, maxval=5.0, step=0.1, group="Risk Management")
i_tp_mult = input.float(3.0, "TP Multiplier (× ATR)", minval=1.0, maxval=10.0, step=0.5, group="Risk Management")
i_risk_pct = input.float(1.0, "Risk % per Trade", minval=0.1, maxval=5.0, step=0.1, group="Risk Management")
i_capital = input.float(5000, "Capital (€)", minval=100, group="Risk Management")

// Exit mode settings
i_exit_mode = input.string("Trailing Stop", "Exit Mode", options=["Fixed TP", "Trailing Stop", "Partial + Trail"], tooltip="Fixed TP: exit 100% at TP.\nTrailing Stop: BE at +1R, trail at +2R.\nPartial + Trail: 50% at +2R, trail rest with ATR stop.", group="Trailing Stop")
i_trail_atr_mult = input.float(2.0, "Trail ATR Multiplier", minval=0.5, maxval=5.0, step=0.1, tooltip="ATR multiplier for trailing stop distance after +2R (used in Partial + Trail mode).", group="Trailing Stop")
i_show_trail = input.bool(true, "Show Trailing Stop Line", tooltip="Show the dynamic trailing stop level on the chart.", group="Trailing Stop")

// Display settings
i_show_signals = input.bool(true, "Show Entry Arrows", group="Display")
i_show_sl_tp = input.bool(true, "Show SL/TP Lines on Entry", group="Display")
i_show_bg = input.bool(true, "Show Trend Background", group="Display")
i_show_vwap = input.bool(true, "Show VWAP", group="Display")
i_show_table = input.bool(true, "Show Info Table", group="Display")
i_table_pos = input.string("Top Right", "Table Position", options=["Top Right", "Top Left", "Bottom Right", "Bottom Left"], group="Display")

// Pullback sensitivity
i_touch_pct = input.float(0.15, "EMA Touch Threshold %", minval=0.01, maxval=1.0, step=0.01, tooltip="How close price must get to EMA20 to count as a 'touch'. Lower = stricter.", group="Pullback Settings")
i_rejection_bars = input.int(3, "Max Bars for Rejection", minval=1, maxval=10, tooltip="After touching EMA20, how many bars to wait for rejection candle.", group="Pullback Settings")

// Session filter settings
i_session_filter = input.bool(true, "Enable Session Filter", tooltip="Only allow entry signals during high-quality trading windows. Prevents entries in dead zones.", group="Session Filter")
i_sess_london_start = input.int(8, "London Open Start (CET hour)", minval=0, maxval=23, group="Session Filter")
i_sess_london_end = input.int(10, "London Open End (CET hour)", minval=0, maxval=23, group="Session Filter")
i_sess_nyse_start = input.int(15, "NYSE Open Start (CET hour)", minval=0, maxval=23, group="Session Filter")
i_sess_nyse_end = input.int(18, "NYSE/Overlap End (CET hour)", minval=0, maxval=23, group="Session Filter")
i_dead_start = input.int(11, "Dead Zone Start (CET hour)", minval=0, maxval=23, group="Session Filter")
i_dead_end = input.int(14, "Dead Zone End (CET hour)", minval=0, maxval=23, group="Session Filter")
i_show_session_bg = input.bool(true, "Show Session Background", tooltip="Highlight active trading sessions on the chart.", group="Session Filter")

// ─────────────────────────────────────────────────────────────────────
// CALCULATIONS
// ─────────────────────────────────────────────────────────────────────

// EMAs
ema_fast = ta.ema(close, i_ema_fast)
ema_slow = ta.ema(close, i_ema_slow)

// Trend structure
bullish_structure = ema_fast > ema_slow
bearish_structure = ema_fast < ema_slow

// RSI
rsi = ta.rsi(close, i_rsi_len)
rsi_ok_long = rsi < i_rsi_ob
rsi_ok_short = rsi > i_rsi_os

// ATR
atr = ta.atr(i_atr_len)
atr_pct = (atr / close) * 100

// VWAP
vwap_val = ta.vwap(hlc3)
above_vwap = close > vwap_val
below_vwap = close < vwap_val

// MACD
[macd_line, signal_line, hist_line] = ta.macd(close, 12, 26, 9)
macd_bullish = hist_line > 0
macd_bearish = hist_line < 0

// ─────────────────────────────────────────────────────────────────────
// SESSION TIME FILTER
// ─────────────────────────────────────────────────────────────────────

// Get current hour in CET/CEST (Europe/Rome handles DST automatically)
cet_hour = hour(time, "Europe/Rome")

// Session window detection
in_london = cet_hour >= i_sess_london_start and cet_hour < i_sess_london_end
in_nyse = cet_hour >= i_sess_nyse_start and cet_hour < i_sess_nyse_end
in_dead_zone = cet_hour >= i_dead_start and cet_hour < i_dead_end
in_active_session = in_london or in_nyse

// Session filter: allow signals only during active sessions (or when filter is disabled)
session_ok = not i_session_filter or in_active_session

// Current session name for display
session_name = in_london ? "London" : in_nyse ? "NYSE" : in_dead_zone ? "Dead Zone" : "Off-Hours"

// ─────────────────────────────────────────────────────────────────────
// EFFECTIVE REGIME (flags override to NEUTRAL)
// ─────────────────────────────────────────────────────────────────────

effective_regime = i_flags ? "NEUTRAL" : i_regime

// ─────────────────────────────────────────────────────────────────────
// PULLBACK DETECTION — EMA20 Touch + Rejection
// ─────────────────────────────────────────────────────────────────────

// Distance from EMA20 as percentage
dist_to_ema = math.abs(close - ema_fast) / ema_fast * 100
touched_ema = dist_to_ema <= i_touch_pct

// Track if price touched EMA20 recently (within N bars)
var int bars_since_touch = 100
if touched_ema
    bars_since_touch := 0
else
    bars_since_touch += 1

recent_touch = bars_since_touch <= i_rejection_bars

// ── LONG PULLBACK: price dips to EMA20, then bounces above ──
// Candle must close above EMA20 after recent touch, coming from below/at EMA20
long_rejection = recent_touch and close > ema_fast and close > open and low <= ema_fast * (1 + i_touch_pct / 100)

// ── SHORT PULLBACK: price rallies to EMA20, then rejects below ──
// Candle must close below EMA20 after recent touch, coming from above/at EMA20
short_rejection = recent_touch and close < ema_fast and close < open and high >= ema_fast * (1 - i_touch_pct / 100)

// ─────────────────────────────────────────────────────────────────────
// ENTRY CONDITIONS
// ─────────────────────────────────────────────────────────────────────

// All pre-conditions for LONG
long_preconditions = bullish_structure and above_vwap and rsi_ok_long

// All pre-conditions for SHORT
short_preconditions = bearish_structure and below_vwap and rsi_ok_short

// Full LONG signal: regime + structure + pullback + bias + session filter
long_signal = effective_regime == "LONG" and long_preconditions and long_rejection and i_bias != "BEARISH" and session_ok

// Full SHORT signal: regime + structure + pullback + bias + session filter
short_signal = effective_regime == "SHORT" and short_preconditions and short_rejection and i_bias != "BULLISH" and session_ok

// Prevent repeated signals — only fire on first bar of signal
var bool in_long = false
var bool in_short = false

long_entry = long_signal and not in_long
short_entry = short_signal and not in_short

if long_entry
    in_long := true
    in_short := false
if short_entry
    in_short := true
    in_long := false

// Reset position state when structure breaks
if in_long and not bullish_structure
    in_long := false
if in_short and not bearish_structure
    in_short := false

// ─────────────────────────────────────────────────────────────────────
// SL / TP CALCULATIONS + TRAILING STOP ENGINE
// ─────────────────────────────────────────────────────────────────────

var float entry_price = na
var float sl_price = na
var float tp_price = na
var float position_size = na

// Trailing stop state
var float one_r = na             // 1R = initial risk distance (always positive)
var float trail_sl = na          // current trailing stop level
var int trail_stage = 0          // 0=initial SL, 1=breakeven, 2=trailing
var bool partial_taken = false   // whether 50% partial TP was taken (Partial+Trail mode)
var float max_favorable = na     // highest high (long) or lowest low (short) since entry
var bool trail_active = false    // is trailing mode active?

// Exit detection
var bool hit_sl = false
var bool hit_tp = false
var bool hit_trail = false

hit_sl := false
hit_tp := false
hit_trail := false

// ── Initialize on LONG entry ──
if long_entry
    entry_price := close
    sl_price := close - atr * i_sl_mult
    one_r := close - sl_price
    trail_sl := sl_price
    trail_stage := 0
    partial_taken := false
    max_favorable := high
    trail_active := i_exit_mode != "Fixed TP"
    if i_exit_mode == "Fixed TP"
        tp_price := close + atr * i_tp_mult
    else
        tp_price := na  // no fixed TP in trailing modes
    sl_dist = one_r
    position_size := sl_dist > 0 ? (i_capital * i_risk_pct / 100) / sl_dist : 0

// ── Initialize on SHORT entry ──
if short_entry
    entry_price := close
    sl_price := close + atr * i_sl_mult
    one_r := sl_price - close
    trail_sl := sl_price
    trail_stage := 0
    partial_taken := false
    max_favorable := low
    trail_active := i_exit_mode != "Fixed TP"
    if i_exit_mode == "Fixed TP"
        tp_price := close - atr * i_tp_mult
    else
        tp_price := na
    sl_dist = one_r
    position_size := sl_dist > 0 ? (i_capital * i_risk_pct / 100) / sl_dist : 0

// ── Trailing stop logic (runs every bar while in position) ──
if in_long and trail_active and not na(entry_price) and not na(one_r) and one_r > 0
    // Track maximum favorable excursion
    max_favorable := math.max(nz(max_favorable, high), high)
    current_r = (max_favorable - entry_price) / one_r

    // Stage 0 → 1: Price reached +1R → move SL to breakeven
    if trail_stage == 0 and current_r >= 1.0
        trail_stage := 1
        trail_sl := entry_price

    // Stage 1 → 2: Price reached +2R → start trailing
    if trail_stage == 1 and current_r >= 2.0
        trail_stage := 2
        if i_exit_mode == "Partial + Trail"
            partial_taken := true
            // In Partial+Trail, trail with ATR-based distance
            trail_sl := math.max(nz(trail_sl), max_favorable - atr * i_trail_atr_mult)
        else
            // In Trailing Stop mode, trail at 1R behind the high
            trail_sl := math.max(nz(trail_sl), max_favorable - one_r)

    // Stage 2: Keep trailing — SL only moves up, never down
    if trail_stage == 2
        if i_exit_mode == "Partial + Trail"
            trail_sl := math.max(nz(trail_sl), max_favorable - atr * i_trail_atr_mult)
        else
            trail_sl := math.max(nz(trail_sl), max_favorable - one_r)

    // Check if trailing stop was hit
    if low <= trail_sl
        hit_trail := true
        in_long := false

if in_short and trail_active and not na(entry_price) and not na(one_r) and one_r > 0
    // Track maximum favorable excursion (lowest low for shorts)
    max_favorable := math.min(nz(max_favorable, low), low)
    current_r = (entry_price - max_favorable) / one_r

    // Stage 0 → 1: Price reached +1R → move SL to breakeven
    if trail_stage == 0 and current_r >= 1.0
        trail_stage := 1
        trail_sl := entry_price

    // Stage 1 → 2: Price reached +2R → start trailing
    if trail_stage == 1 and current_r >= 2.0
        trail_stage := 2
        if i_exit_mode == "Partial + Trail"
            partial_taken := true
            trail_sl := math.min(nz(trail_sl), max_favorable + atr * i_trail_atr_mult)
        else
            trail_sl := math.min(nz(trail_sl), max_favorable + one_r)

    // Stage 2: Keep trailing — SL only moves down, never up
    if trail_stage == 2
        if i_exit_mode == "Partial + Trail"
            trail_sl := math.min(nz(trail_sl), max_favorable + atr * i_trail_atr_mult)
        else
            trail_sl := math.min(nz(trail_sl), max_favorable + one_r)

    // Check if trailing stop was hit
    if high >= trail_sl
        hit_trail := true
        in_short := false

// ── Fixed TP / Fixed SL exit detection ──
if in_long and i_exit_mode == "Fixed TP" and not na(tp_price)
    if high >= tp_price
        hit_tp := true
        in_long := false
    if low <= sl_price
        hit_sl := true
        in_long := false

if in_short and i_exit_mode == "Fixed TP" and not na(tp_price)
    if low <= tp_price
        hit_tp := true
        in_short := false
    if high >= sl_price
        hit_sl := true
        in_short := false

// ── Initial SL hit in trailing modes (before +1R breakeven) ──
if in_long and trail_active and trail_stage == 0 and not na(trail_sl)
    if low <= trail_sl
        hit_sl := true
        in_long := false

if in_short and trail_active and trail_stage == 0 and not na(trail_sl)
    if high >= trail_sl
        hit_sl := true
        in_short := false

// ─────────────────────────────────────────────────────────────────────
// PLOTTING — EMAs, VWAP, Background
// ─────────────────────────────────────────────────────────────────────

// EMAs
plot(ema_fast, "EMA Fast", color=color.new(#f97316, 0), linewidth=2)  // Orange
plot(ema_slow, "EMA Slow", color=color.new(#3b82f6, 0), linewidth=2)  // Blue

// VWAP
plot(i_show_vwap ? vwap_val : na, "VWAP", color=color.new(#ffffff, 30), linewidth=1, style=plot.style_circles)

// Trend background
bg_color = not i_show_bg ? na : bullish_structure ? color.new(#22c55e, 92) : bearish_structure ? color.new(#ef4444, 92) : na
bgcolor(bg_color, title="Trend Background")

// Regime background — subtle highlight when regime is active
regime_color = effective_regime == "LONG" ? color.new(#22c55e, 96) : effective_regime == "SHORT" ? color.new(#ef4444, 96) : na
bgcolor(regime_color, title="Regime Background")

// Session background — green for active, red for dead zone
session_bg = not i_show_session_bg ? na : in_active_session ? color.new(#3b82f6, 95) : in_dead_zone ? color.new(#ef4444, 97) : na
bgcolor(session_bg, title="Session Background")

// ─────────────────────────────────────────────────────────────────────
// PLOTTING — Entry Arrows
// ─────────────────────────────────────────────────────────────────────

plotshape(i_show_signals and long_entry, "LONG Entry", shape.triangleup, location.belowbar, color.new(#22c55e, 0), size=size.normal, text="LONG")
plotshape(i_show_signals and short_entry, "SHORT Entry", shape.triangledown, location.abovebar, color.new(#ef4444, 0), size=size.normal, text="SHORT")

// ─────────────────────────────────────────────────────────────────────
// PLOTTING — Exit Markers
// ─────────────────────────────────────────────────────────────────────

plotshape(hit_tp, "TP Hit", shape.xcross, location.abovebar, color.new(#22c55e, 0), size=size.small, text="TP")
plotshape(hit_sl, "SL Hit", shape.xcross, location.belowbar, color.new(#ef4444, 0), size=size.small, text="SL")
plotshape(hit_trail, "Trail Exit", shape.xcross, location.abovebar, color.new(#f59e0b, 0), size=size.small, text="TRAIL")

// Partial TP marker (50% exit at +2R in Partial+Trail mode)
plotshape(i_exit_mode == "Partial + Trail" and partial_taken and trail_stage == 2 and trail_stage[1] == 1, "Partial TP", shape.flag, location.abovebar, color.new(#8b5cf6, 0), size=size.small, text="50%")

// ─────────────────────────────────────────────────────────────────────
// PLOTTING — SL/TP/Trail Lines (dynamic, update every bar)
// ─────────────────────────────────────────────────────────────────────

var line sl_line = na
var line tp_line = na
var line entry_line = na
var line trail_line = na
var label sl_label = na
var label tp_label = na
var label trail_label = na

// Breakeven marker line
var line be_line = na
var label be_label = na

// Clean up all lines on new entry or exit
should_draw = (in_long or in_short) and i_show_sl_tp and not na(entry_price)

if (long_entry or short_entry or hit_sl or hit_tp or hit_trail) and i_show_sl_tp
    if not na(sl_line)
        line.delete(sl_line)
    if not na(tp_line)
        line.delete(tp_line)
    if not na(entry_line)
        line.delete(entry_line)
    if not na(trail_line)
        line.delete(trail_line)
    if not na(sl_label)
        label.delete(sl_label)
    if not na(tp_label)
        label.delete(tp_label)
    if not na(trail_label)
        label.delete(trail_label)
    if not na(be_line)
        line.delete(be_line)
    if not na(be_label)
        label.delete(be_label)

// Draw lines on entry
if (long_entry or short_entry) and i_show_sl_tp
    entry_line := line.new(bar_index, entry_price, bar_index + 50, entry_price, color=color.new(#ffffff, 30), style=line.style_dashed, width=1)

    if i_exit_mode == "Fixed TP" and not na(tp_price)
        // Fixed mode: show static SL and TP
        sl_line := line.new(bar_index, sl_price, bar_index + 50, sl_price, color=color.new(#ef4444, 0), style=line.style_solid, width=2)
        tp_line := line.new(bar_index, tp_price, bar_index + 50, tp_price, color=color.new(#22c55e, 0), style=line.style_solid, width=2)
        sl_label := label.new(bar_index + 52, sl_price, "SL " + str.tostring(sl_price, format.mintick), color=color.new(#ef4444, 80), textcolor=#ef4444, style=label.style_label_left, size=size.small)
        tp_label := label.new(bar_index + 52, tp_price, "TP " + str.tostring(tp_price, format.mintick), color=color.new(#22c55e, 80), textcolor=#22c55e, style=label.style_label_left, size=size.small)
    else
        // Trailing modes: show initial SL + breakeven reference
        sl_line := line.new(bar_index, trail_sl, bar_index + 50, trail_sl, color=color.new(#ef4444, 0), style=line.style_solid, width=2)
        sl_label := label.new(bar_index + 52, trail_sl, "SL " + str.tostring(trail_sl, format.mintick), color=color.new(#ef4444, 80), textcolor=#ef4444, style=label.style_label_left, size=size.small)
        // Breakeven reference line (dashed, subtle)
        be_line := line.new(bar_index, entry_price, bar_index + 50, entry_price, color=color.new(#eab308, 60), style=line.style_dotted, width=1)
        be_label := label.new(bar_index + 52, entry_price, "BE", color=color.new(#eab308, 80), textcolor=#eab308, style=label.style_label_left, size=size.tiny)

// Update trailing stop line dynamically every bar (trailing modes only)
if should_draw and trail_active and not (long_entry or short_entry)
    // Delete old trail line and redraw at current level
    if not na(trail_line)
        line.delete(trail_line)
    if not na(trail_label)
        label.delete(trail_label)
    if not na(sl_line)
        line.delete(sl_line)
    if not na(sl_label)
        label.delete(sl_label)

    // Color changes by stage: red=initial, yellow=breakeven, orange=trailing
    trail_col = trail_stage == 0 ? #ef4444 : trail_stage == 1 ? #eab308 : #f97316
    stage_txt = trail_stage == 0 ? "SL" : trail_stage == 1 ? "BE" : "TRAIL"
    r_txt = not na(one_r) and one_r > 0 ? " (" + str.tostring((trail_sl - entry_price) / one_r, "+#.1") + "R)" : ""
    if in_short and not na(one_r) and one_r > 0
        r_txt := " (" + str.tostring((entry_price - trail_sl) / one_r, "+#.1") + "R)"

    trail_line := line.new(bar_index - 20, trail_sl, bar_index + 10, trail_sl, color=color.new(trail_col, 0), style=trail_stage >= 2 ? line.style_solid : line.style_dashed, width=2)
    trail_label := label.new(bar_index + 12, trail_sl, stage_txt + " " + str.tostring(trail_sl, format.mintick) + r_txt, color=color.new(trail_col, 80), textcolor=trail_col, style=label.style_label_left, size=size.small)

// ── R-multiple reference lines (+1R, +2R, +3R) for trailing modes ──
var line r1_line = na
var line r2_line = na
var line r3_line = na
var label r1_label = na
var label r2_label = na
var label r3_label = na

if (long_entry or short_entry) and trail_active and i_show_sl_tp
    if not na(r1_line)
        line.delete(r1_line)
    if not na(r2_line)
        line.delete(r2_line)
    if not na(r3_line)
        line.delete(r3_line)
    if not na(r1_label)
        label.delete(r1_label)
    if not na(r2_label)
        label.delete(r2_label)
    if not na(r3_label)
        label.delete(r3_label)

    if in_long and not na(one_r)
        r1_lvl = entry_price + one_r
        r2_lvl = entry_price + 2 * one_r
        r3_lvl = entry_price + 3 * one_r
        r1_line := line.new(bar_index, r1_lvl, bar_index + 50, r1_lvl, color=color.new(#22c55e, 70), style=line.style_dotted, width=1)
        r2_line := line.new(bar_index, r2_lvl, bar_index + 50, r2_lvl, color=color.new(#22c55e, 60), style=line.style_dotted, width=1)
        r3_line := line.new(bar_index, r3_lvl, bar_index + 50, r3_lvl, color=color.new(#22c55e, 50), style=line.style_dotted, width=1)
        r1_label := label.new(bar_index + 52, r1_lvl, "+1R", color=color.new(#22c55e, 90), textcolor=color.new(#22c55e, 50), style=label.style_label_left, size=size.tiny)
        r2_label := label.new(bar_index + 52, r2_lvl, "+2R", color=color.new(#22c55e, 90), textcolor=color.new(#22c55e, 50), style=label.style_label_left, size=size.tiny)
        r3_label := label.new(bar_index + 52, r3_lvl, "+3R", color=color.new(#22c55e, 90), textcolor=color.new(#22c55e, 50), style=label.style_label_left, size=size.tiny)

    if in_short and not na(one_r)
        r1_lvl = entry_price - one_r
        r2_lvl = entry_price - 2 * one_r
        r3_lvl = entry_price - 3 * one_r
        r1_line := line.new(bar_index, r1_lvl, bar_index + 50, r1_lvl, color=color.new(#ef4444, 70), style=line.style_dotted, width=1)
        r2_line := line.new(bar_index, r2_lvl, bar_index + 50, r2_lvl, color=color.new(#ef4444, 60), style=line.style_dotted, width=1)
        r3_line := line.new(bar_index, r3_lvl, bar_index + 50, r3_lvl, color=color.new(#ef4444, 50), style=line.style_dotted, width=1)
        r1_label := label.new(bar_index + 52, r1_lvl, "+1R", color=color.new(#ef4444, 90), textcolor=color.new(#ef4444, 50), style=label.style_label_left, size=size.tiny)
        r2_label := label.new(bar_index + 52, r2_lvl, "+2R", color=color.new(#ef4444, 90), textcolor=color.new(#ef4444, 50), style=label.style_label_left, size=size.tiny)
        r3_label := label.new(bar_index + 52, r3_lvl, "+3R", color=color.new(#ef4444, 90), textcolor=color.new(#ef4444, 50), style=label.style_label_left, size=size.tiny)

// ─────────────────────────────────────────────────────────────────────
// PLOTTING — Trailing Stop as continuous plot line
// ─────────────────────────────────────────────────────────────────────

// Continuous trail SL plot (visible when in position with trailing active)
trail_plot_val = (in_long or in_short) and trail_active and not na(trail_sl) and i_show_trail ? trail_sl : na
trail_plot_col = trail_stage == 0 ? color.new(#ef4444, 30) : trail_stage == 1 ? color.new(#eab308, 30) : color.new(#f97316, 0)
plot(trail_plot_val, "Trailing Stop", color=trail_plot_col, linewidth=2, style=plot.style_stepline)

// ─────────────────────────────────────────────────────────────────────
// PLOTTING — Pre-condition dots (structure ready but no pullback yet)
// ─────────────────────────────────────────────────────────────────────

// Small dots when structure is aligned but waiting for pullback
long_ready = effective_regime == "LONG" and long_preconditions and not long_entry and not in_long
short_ready = effective_regime == "SHORT" and short_preconditions and not short_entry and not in_short

plotshape(long_ready and touched_ema, "Pullback Touch (Long)", shape.diamond, location.belowbar, color.new(#22c55e, 60), size=size.tiny)
plotshape(short_ready and touched_ema, "Pullback Touch (Short)", shape.diamond, location.abovebar, color.new(#ef4444, 60), size=size.tiny)

// ─────────────────────────────────────────────────────────────────────
// ALERTS
// ─────────────────────────────────────────────────────────────────────

alertcondition(long_entry, "LONG Entry Signal", "Trading Copilot: LONG entry confirmed — EMA20 pullback bounce")
alertcondition(short_entry, "SHORT Entry Signal", "Trading Copilot: SHORT entry confirmed — EMA20 pullback rejection")
alertcondition(long_ready and touched_ema, "LONG Pullback Touch", "Trading Copilot: Price touching EMA20 — watch for bounce (LONG regime)")
alertcondition(short_ready and touched_ema, "SHORT Pullback Touch", "Trading Copilot: Price touching EMA20 — watch for rejection (SHORT regime)")

// Trailing stop alerts
alertcondition(trail_stage == 1 and trail_stage[1] == 0, "Breakeven Reached", "Trading Copilot: +1R reached — SL moved to breakeven (zero risk)")
alertcondition(trail_stage == 2 and trail_stage[1] == 1, "Trailing Active", "Trading Copilot: +2R reached — trailing stop activated")
alertcondition(hit_trail, "Trail Stop Hit", "Trading Copilot: Trailing stop hit — position closed")
alertcondition(hit_tp, "Fixed TP Hit", "Trading Copilot: Fixed TP target reached — position closed")
alertcondition(hit_sl, "SL Hit", "Trading Copilot: Stop loss hit — position closed")

// Session alerts
alertcondition(in_london and not in_london[1], "London Open", "Trading Copilot: London session opened — high-quality window")
alertcondition(in_nyse and not in_nyse[1], "NYSE Open", "Trading Copilot: NYSE session opened — high-quality window")
alertcondition(in_dead_zone and not in_dead_zone[1], "Dead Zone Start", "Trading Copilot: Dead zone entered — avoid new entries")

// ─────────────────────────────────────────────────────────────────────
// INFO TABLE
// ─────────────────────────────────────────────────────────────────────

if barstate.islast and i_show_table
    // Table position
    t_pos = switch i_table_pos
        "Top Right"    => position.top_right
        "Top Left"     => position.top_left
        "Bottom Right" => position.bottom_right
        "Bottom Left"  => position.bottom_left
        => position.top_right

    // Table rows: 18 base + 3 session rows = 21
    var table info = table.new(t_pos, 2, 21, bgcolor=color.new(#1e1e2e, 10), border_color=color.new(#6b7280, 50), border_width=1, frame_color=color.new(#6b7280, 50), frame_width=1)

    // Header
    table.cell(info, 0, 0, "TRADING COPILOT", text_color=#ffffff, text_size=size.normal, bgcolor=color.new(#3b82f6, 20), text_halign=text.align_center)
    table.merge_cells(info, 0, 0, 1, 0)

    // Regime
    regime_col = effective_regime == "LONG" ? #22c55e : effective_regime == "SHORT" ? #ef4444 : #eab308
    regime_txt = effective_regime + (i_flags ? " (FLAGS!)" : "")
    table.cell(info, 0, 1, "Regime", text_color=#9ca3af, text_size=size.small)
    table.cell(info, 1, 1, regime_txt, text_color=regime_col, text_size=size.small)

    // LLM Bias
    bias_col = i_bias == "BULLISH" ? #22c55e : i_bias == "BEARISH" ? #ef4444 : #eab308
    table.cell(info, 0, 2, "LLM Bias", text_color=#9ca3af, text_size=size.small)
    table.cell(info, 1, 2, i_bias, text_color=bias_col, text_size=size.small)

    // Confidence
    table.cell(info, 0, 3, "Confidence", text_color=#9ca3af, text_size=size.small)
    table.cell(info, 1, 3, str.tostring(i_confidence) + "%", text_color=#ffffff, text_size=size.small)

    // Separator
    table.cell(info, 0, 4, "── TECHNICALS ──", text_color=#6b7280, text_size=size.tiny, text_halign=text.align_center)
    table.merge_cells(info, 0, 4, 1, 4)

    // EMA Trend
    ema_col = bullish_structure ? #22c55e : bearish_structure ? #ef4444 : #eab308
    ema_txt = bullish_structure ? "BULLISH" : bearish_structure ? "BEARISH" : "FLAT"
    table.cell(info, 0, 5, "EMA " + str.tostring(i_ema_fast) + "/" + str.tostring(i_ema_slow), text_color=#9ca3af, text_size=size.small)
    table.cell(info, 1, 5, ema_txt, text_color=ema_col, text_size=size.small)

    // RSI
    rsi_col = rsi > i_rsi_ob ? #ef4444 : rsi < i_rsi_os ? #22c55e : #ffffff
    rsi_status = rsi > i_rsi_ob ? " OB" : rsi < i_rsi_os ? " OS" : ""
    table.cell(info, 0, 6, "RSI(" + str.tostring(i_rsi_len) + ")", text_color=#9ca3af, text_size=size.small)
    table.cell(info, 1, 6, str.tostring(rsi, "#.1") + rsi_status, text_color=rsi_col, text_size=size.small)

    // VWAP
    vwap_col = above_vwap ? #22c55e : #ef4444
    vwap_txt = above_vwap ? "ABOVE" : "BELOW"
    vwap_dist_pct = (close - vwap_val) / vwap_val * 100
    table.cell(info, 0, 7, "vs VWAP", text_color=#9ca3af, text_size=size.small)
    table.cell(info, 1, 7, vwap_txt + " (" + str.tostring(vwap_dist_pct, "+#.2") + "%)", text_color=vwap_col, text_size=size.small)

    // MACD
    macd_col = macd_bullish ? #22c55e : #ef4444
    macd_txt = macd_bullish ? "BULLISH" : "BEARISH"
    table.cell(info, 0, 8, "MACD", text_color=#9ca3af, text_size=size.small)
    table.cell(info, 1, 8, macd_txt, text_color=macd_col, text_size=size.small)

    // ATR
    table.cell(info, 0, 9, "ATR(" + str.tostring(i_atr_len) + ")", text_color=#9ca3af, text_size=size.small)
    table.cell(info, 1, 9, str.tostring(atr, format.mintick) + " (" + str.tostring(atr_pct, "#.2") + "%)", text_color=#ffffff, text_size=size.small)

    // Separator — Risk
    table.cell(info, 0, 10, "── RISK ──", text_color=#6b7280, text_size=size.tiny, text_halign=text.align_center)
    table.merge_cells(info, 0, 10, 1, 10)

    // SL distance
    sl_dist = atr * i_sl_mult
    table.cell(info, 0, 11, "SL Distance", text_color=#9ca3af, text_size=size.small)
    table.cell(info, 1, 11, str.tostring(sl_dist, format.mintick) + " pts", text_color=#ef4444, text_size=size.small)

    // TP distance / Exit mode
    if i_exit_mode == "Fixed TP"
        tp_dist = atr * i_tp_mult
        table.cell(info, 0, 12, "TP Distance", text_color=#9ca3af, text_size=size.small)
        table.cell(info, 1, 12, str.tostring(tp_dist, format.mintick) + " pts", text_color=#22c55e, text_size=size.small)
    else
        table.cell(info, 0, 12, "TP Mode", text_color=#9ca3af, text_size=size.small)
        table.cell(info, 1, 12, "TRAILING", text_color=#f97316, text_size=size.small)

    // R:R ratio
    rr = i_exit_mode == "Fixed TP" and i_sl_mult > 0 ? i_tp_mult / i_sl_mult : 0
    rr_txt = i_exit_mode == "Fixed TP" ? "1:" + str.tostring(rr, "#.1") : "OPEN"
    table.cell(info, 0, 13, "R:R", text_color=#9ca3af, text_size=size.small)
    table.cell(info, 1, 13, rr_txt, text_color=#ffffff, text_size=size.small)

    // Separator — Trailing Stop
    table.cell(info, 0, 14, "── TRAIL ──", text_color=#6b7280, text_size=size.tiny, text_halign=text.align_center)
    table.merge_cells(info, 0, 14, 1, 14)

    // Exit mode
    mode_col = i_exit_mode == "Fixed TP" ? #ffffff : i_exit_mode == "Trailing Stop" ? #f97316 : #8b5cf6
    table.cell(info, 0, 15, "Exit Mode", text_color=#9ca3af, text_size=size.small)
    table.cell(info, 1, 15, i_exit_mode, text_color=mode_col, text_size=size.small)

    // Trail stage (only meaningful when in position)
    if (in_long or in_short) and trail_active
        stage_col = trail_stage == 0 ? #ef4444 : trail_stage == 1 ? #eab308 : #f97316
        stage_text = trail_stage == 0 ? "INITIAL" : trail_stage == 1 ? "BREAKEVEN" : "TRAILING"
        table.cell(info, 0, 16, "Trail Stage", text_color=#9ca3af, text_size=size.small)
        table.cell(info, 1, 16, stage_text, text_color=stage_col, text_size=size.small)

        // Current R-multiple
        curr_r = 0.0
        if in_long and not na(entry_price) and not na(one_r) and one_r > 0
            curr_r := (close - entry_price) / one_r
        if in_short and not na(entry_price) and not na(one_r) and one_r > 0
            curr_r := (entry_price - close) / one_r
        r_col = curr_r >= 2.0 ? #22c55e : curr_r >= 1.0 ? #eab308 : curr_r >= 0 ? #ffffff : #ef4444
        table.cell(info, 0, 17, "Current R", text_color=#9ca3af, text_size=size.small)
        table.cell(info, 1, 17, str.tostring(curr_r, "+#.1") + "R", text_color=r_col, text_size=size.small)
    else
        table.cell(info, 0, 16, "Trail Stage", text_color=#9ca3af, text_size=size.small)
        table.cell(info, 1, 16, "—", text_color=#6b7280, text_size=size.small)
        table.cell(info, 0, 17, "Current R", text_color=#9ca3af, text_size=size.small)
        table.cell(info, 1, 17, "—", text_color=#6b7280, text_size=size.small)

    // Separator — Session
    table.cell(info, 0, 18, "── SESSION ──", text_color=#6b7280, text_size=size.tiny, text_halign=text.align_center)
    table.merge_cells(info, 0, 18, 1, 18)

    // Current session
    sess_col = in_active_session ? #22c55e : in_dead_zone ? #ef4444 : #eab308
    sess_status = i_session_filter ? (session_ok ? "ACTIVE" : "BLOCKED") : "OFF"
    table.cell(info, 0, 19, "Session", text_color=#9ca3af, text_size=size.small)
    table.cell(info, 1, 19, session_name, text_color=sess_col, text_size=size.small)

    // Filter status
    filter_col = not i_session_filter ? #6b7280 : session_ok ? #22c55e : #ef4444
    table.cell(info, 0, 20, "Filter", text_color=#9ca3af, text_size=size.small)
    table.cell(info, 1, 20, sess_status, text_color=filter_col, text_size=size.small)
